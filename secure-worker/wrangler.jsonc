{
  "name": "secure-worker",
  "main": "index.js",
  "compatibility_date": "2026-07-10",
  "routes": [
    {
      "pattern": "tunnel.nespray14.org/secure*",
      "zone_name": "nespray14.org"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FLAG_BUCKET",
      "bucket_name": "flags"
    }
  ]
}
